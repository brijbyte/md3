{
  "name": "@brijbyte/md3-icons",
  "version": "0.0.1",
  "description": "Google Material Symbols (weight 400) as per-icon React components",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "node scripts/build-icons.mjs",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@material-symbols/svg-400": "^0.45.5",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  }
}
