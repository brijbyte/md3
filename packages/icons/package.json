{
  "name": "@brijbyte/md3-icons",
  "version": "0.0.0",
  "description": "Google Material Symbols (weight 400) as per-icon React components",
  "license": "MIT AND Apache-2.0",
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "LICENSE-APACHE-2.0",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./createIcon": {
      "types": "./dist/createIcon.d.ts",
      "import": "./dist/createIcon.js"
    },
    "./*": {
      "types": "./dist/icon.d.ts",
      "import": "./dist/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build-icons.mjs",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  }
}
