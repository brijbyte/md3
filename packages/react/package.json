{
  "name": "@brijbyte/md3-react",
  "version": "0.0.1",
  "description": "Material Design 3 components for React, built on Base UI",
  "license": "MIT",
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "bin": {
    "md3": "./bin/md3.mjs"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./*.css": "./dist/styles/*.css"
  },
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:shapes": "node scripts/build-loading-indicator-shapes.mjs && node scripts/build-circular-progress-shapes.mjs",
    "typegen:css": "tcm --pattern 'src/**/*.module.css'",
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typed-css-modules": "^0.9.1",
    "vite-plugin-dts": "^5.0.3"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
