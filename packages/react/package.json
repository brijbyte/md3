{
  "name": "@brijbyte/md3-react",
  "version": "0.0.1",
  "description": "Material Design 3 components for React, built on Base UI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brijbyte/md3.git",
    "directory": "packages/react"
  },
  "bin": {
    "md3": "./bin/md3.mjs"
  },
  "files": [
    "dist",
    "bin",
    "src",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./styles.css": "./dist/index.css",
    "./*.css": "./dist/styles/*.css",
    "./*": {
      "style": "./dist/styles/*.css",
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:shapes": "node scripts/build-loading-indicator-shapes.mjs && node scripts/build-circular-progress-shapes.mjs",
    "typegen:css": "tcm --pattern 'src/**/*.module.css'",
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tsdown/css": "^0.22.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.17",
    "postcss-modules": "^9.0.1",
    "tsdown": "^0.22.12",
    "typed-css-modules": "^0.9.1",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.0.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
