{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    // Points at library source (not dist) for instant HMR and go-to-source;
    // Vite picks these up via vite-tsconfig-paths.
    "paths": {
      "@brijbyte/md3-react": ["../../packages/react/src/index.ts"],
      "@brijbyte/md3-react/styles.css": ["../../packages/react/src/dev-styles.css"]
    }
  },
  "include": ["src"]
}
