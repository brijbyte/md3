{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["vite/client", "@vitejs/plugin-rsc/types"],
    // Points at library source (not dist) for instant HMR and go-to-source;
    // Vite picks these up via vite-tsconfig-paths.
    "paths": {
      "@brijbyte/md3-react/tokens.css": ["../../packages/react/src/generated/tokens.css"],
      "@brijbyte/md3-react/tailwind-tokens.css": [
        "../../packages/react/src/generated/tailwind-tokens.css"
      ],
      "@brijbyte/md3-react/*": ["../../packages/react/src/*/index.ts"]
    }
  },
  "include": ["src"]
}
